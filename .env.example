# Ghost Configuration
# See https://ghost.org/docs/config/ for full documentation

# The public URL of your deployed Ghost instance (railway provides this automatically)
# Set during deploy via Railway project settings:
url=https://your-app.railway.app

# --------------------------------------------------
# Database Configuration (set via DATABASE_URL or individual vars)
# Add a PostgreSQL service on Railway; connection details auto-filled
# --------------------------------------------------

# Single-connection string (preferred):
DATABASE_URL=postgresql://user:password@host:5432/ghost_database

# Individual fields (alternative -- ignored if DATABASE_URL is set):
database__client=postgres
database__connection__host=${DB_HOST:-localhost}
database__connection__port=${DB_PORT:-5432}
database__connection__user=${DB_USER:-postgres}
database__connection__password=${DB_PASSWORD:""}
database__connection__database=${DB_NAME:-ghost}

# --------------------------------------------------
# Email Configuration
# Add an SMTP service on Railway or use Ghost(Pro) email
# --------------------------------------------------

# Mail transport (options: smtp, direct, mailgun, sendmail)
mail__transport=direct
# mail__transport=smtp

# SMTP settings (required if mail__transport=smtp):
# MAIL_OPTIONS_HOST=smtp.example.com
# MAIL_OPTIONS_PORT=587
# MAIL_OPTIONS_SECURE=true
# MAIL_OPTIONS_AUTH_USER=user
# MAIL_OPTIONS_AUTH_PASS=password
